  m_Script: {fileID: 11500000, guid: a8f3c2e19b4d5640a1e7f9c82d6b3e41, type: 3}
  m_Name: SecondLevelStory
  m_EditorClassIdentifier: 
  SceneName: SecondLevel
  IntroLines:
  - "\u041B\u0435\u0441 \u043C\u0435\u0440\u0442\u0432. \u0414\u0430\u0436\u0435 \u0432\u0435\u0442\u0435\u0440 \u0437\u0430\u0442\u0438\u0445. \u041D\u0430 \u0432\u0435\u0442\u043A\u0435 \u2014 \u043E\u0431\u0440\u044B\u0432\u043E\u043A \u0437\u043D\u0430\u043C\u0435\u043D\u0438 \u043E\u043F\u043E\u043B\u0447\u0435\u043D\u0438\u044F."
  - "\u041D\u0430 \u0442\u043A\u0430\u043D\u0438 \u0432\u044B\u0448\u0438\u0442 \u043A\u0440\u043E\u0432\u044C\u044E: \"\u0414\u0435\u0440\u0436\u0438\u043C \u043F\u0435\u0440\u0438\u043C\u0435\u0442\u0440 \u0442\u0440\u0438 \u0434\u043D\u044F\". \u041F\u043E\u0442\u043E\u043C \u2014 \u0442\u0438\u0448\u0438\u043D\u0430."
  OutroLines:
  - "\u0421\u043A\u0435\u043B\u0435\u0442\u044B \u0432\u0441\u0451 \u0431\u043B\u0438\u0436\u0435 \u043A \u0431\u0430\u0448\u043D\u0435. \u0417\u043D\u0430\u0447\u0438\u0442, \u043A\u0442\u043E-\u0442\u043E \u043F\u0440\u0438\u043A\u0440\u044B\u0432\u0430\u0435\u0442 \u0438\u0445 \u043A \u043E\u0434\u043D\u043E\u043C\u0443 \u043C\u0435\u0441\u0442\u0443."
  - "\u0412\u043F\u0435\u0440\u0451\u0434 \u0440\u0443\u0438\u043D\u044B. \u0422\u0430\u043C \u0434\u043E\u043B\u0436\u0435\u043D \u0431\u044B\u0442\u044C \u0434\u043D\u0435\u0432\u043D\u0438\u043A \u043A\u0430\u043F\u0438\u0442\u0430\u043D\u0430."
